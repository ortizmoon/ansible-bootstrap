ui = true

listener "tcp" {
  address       = "0.0.0.0:{{ vault_port }}"
  tls_disable   = true
}

storage "raft" {
  path    = "{{ vault_data_dir }}"
  node_id = "vault-01"
}

api_addr     = "http://{{ ansible_host }}:{{ vault_port }}"
cluster_addr = "http://{{ ansible_host }}:{{ vault_cluster_port }}"

disable_mlock = false
